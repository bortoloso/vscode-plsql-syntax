{
  "name": "vscode-plsql-syntax",
  "displayName": "PL/SQL",
  "description": "PL/SQL syntax highlighting for SQL, procedures, packages, triggers, and SQL*Plus scripts",
  "version": "1.2.0",
  "publisher": "bortoloso",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "markdown": "github",
  "repository": {
    "type": "git",
    "url": "https://github.com/bortoloso/vscode-plsql-syntax.git"
  },
  "homepage": "https://github.com/bortoloso/vscode-plsql-syntax#readme",
  "bugs": {
    "url": "https://github.com/bortoloso/vscode-plsql-syntax/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "scripts": {
    "validate:grammar": "node -e \"JSON.parse(require('fs').readFileSync('syntaxes/plsql.tmLanguage.json','utf8')); JSON.parse(require('fs').readFileSync('syntaxes/language-configuration.json','utf8')); console.log('Grammar JSON OK');\"",
    "package": "vsce package",
    "package:ci": "vsce package --out vscode-plsql-syntax.vsix"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "plsql",
    "oracle sql",
    "sqlplus",
    "sql",
    "syntax",
    "highlight",
    "stored procedure",
    "trigger",
    "package",
    "pkb",
    "pks",
    "database"
  ],
  "contributes": {
    "languages": [
      {
        "id": "plsql",
        "aliases": [
          "PL/SQL",
          "PLSQL"
        ],
        "extensions": [
          ".sql",
          ".pls",
          ".plsql",
          ".pks",
          ".pkb",
          ".plb",
          ".fnc",
          ".prc",
          ".trg",
          ".vw",
          ".pkg",
          ".pck",
          ".seq",
          ".job",
          ".src",
          ".act",
          ".bac",
          ".bas",
          ".scr",
          ".ut"
        ],
        "configuration": "./syntaxes/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "plsql",
        "scopeName": "source.plsql",
        "path": "./syntaxes/plsql.tmLanguage.json"
      }
    ]
  }
}
